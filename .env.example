AI_EMBEDDING_MODEL=nomic-embed-text:latest

AI_RETRIEVAL_INITIALIZE_ON_STARTUP=true
SBG_EMBEDDING_BATCH_SIZE=64
AI_RETRIEVAL_TOP_K=8
